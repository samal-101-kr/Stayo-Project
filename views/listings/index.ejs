<% layout("/layouts/boilerplate") %> <%= success %>
<body>
    <style>
        #filters{
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            padding-left: 40px;
        }
        .filter{
            text-align: center;
            margin-right: 2rem;
            margin-top: 2rem;
            opacity: 0.7;
        }
        .filter:hover{
            opacity: 1;
            cursor: pointer;
        }
        .filter p{
            font-size: 0.9rem;
        }
        .tax-info{
            display: none;
        }
        .tax-toggle{
            border: 1px solid black;
            height: 3.2rem;
            border-radius: 1rem;
            padding: 1rem;
            margin-left: 3rem;
            display: flex;
            align-items: center;
        }
        .tax-toggle label{
            cursor: pointer;
        }
        .form-check-input{
            cursor: pointer;
        }
    </style>


<div class="filters">

  <a href="/listings" class="<%= category==='trending'?'active':'' %>">Trending</a>

  <a href="/listings?category=rooms" class="<%= category==='rooms'?'active':'' %>">Rooms</a>

  <a href="/listings?category=iconic" class="<%= category==='iconic'?'active':'' %>">Iconic</a>

  <a href="/listings?category=mountain" class="<%= category==='mountain'?'active':'' %>">Mountain</a>

  <a href="/listings?category=castles" class="<%= category==='castles'?'active':'' %>">Castles</a>

  <a href="/listings?category=pools" class="<%= category==='pools'?'active':'' %>">Pools</a>

  <a href="/listings?category=camping" class="<%= category==='camping'?'active':'' %>">Camping</a>

  <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
</div>

        

        <!-- <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div> -->
    


    <% if(listings.length === 0){ %>
        <div class="not-found">
    <h3 style="text-align: center;">No listings found for this category 😢</h3>
</div>
<% } %>
        

    <div class="row mt-3 gx-3 gy-4 px-2 px-md-3 px-lg-4">
  <% for(let listing of listings){ %>
    <div class="col-lg-4 col-md-6 col-12">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card h-100 listing-card">
          <img src="<%= listing.image.url %>" class="card-img-top" alt="image">
          <div class="card-body">
           <p class="card-text">
                <b><%= listing.title %></b> <br>
                <span class="price" data-price="<%= listing.price %>">
                    ₹<%= listing.price.toLocaleString("en-IN") %>
                </span>
                <i class="tax-info">+18% GST</i>
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>
   
</body>

