<script>
    
let taxSwitch = document.getElementById("switchCheckDefault");

taxSwitch.addEventListener("change", () => {
    let prices = document.querySelectorAll(".price");
    let taxInfo = document.querySelectorAll(".tax-info");

    prices.forEach((priceEl) => {
        let basePrice = Number(priceEl.dataset.price);

        if (taxSwitch.checked) {
            let finalPrice = basePrice + (basePrice * 0.18);
            priceEl.innerText = "₹" + finalPrice.toLocaleString("en-IN");
        } else {
            priceEl.innerText = "₹" + basePrice;
        }
    });

    // show/hide GST text
    taxInfo.forEach((el) => {
        el.style.display = taxSwitch.checked ? "inline" : "none";
    });
});
</script>